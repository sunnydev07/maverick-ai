{
  "name": "maverick-ai",
  "version": "0.1.0",
  "description": "AI-powered Windows system tray application with voice capture and LLM integration",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --recursive run dev",
    "dev:worker": "pnpm -C packages/worker dev",
    "dev:electron": "pnpm -C packages/electron dev",
    "build": "pnpm --recursive run build",
    "type-check": "pnpm --recursive run type-check",
    "install": "pnpm install",
    "setup": "pnpm install && pnpm build",
    "start": "pnpm dev"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "workspaces": [
    "packages/*"
  ]
},
}
